<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog_cert_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_tools_shell"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:padding="22dp">

    <!-- Header chip + label row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="📜"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="CERTIFICATE"
            android:textAllCaps="true"
            android:textColor="@color/hsp_accent_teal"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="CA Certificate"
        android:textColor="@color/hsp_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Dynamic status line -->
    <TextView
        android:id="@+id/dialog_cert_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp" />

    <!-- Cert-loaded detail card -->
    <LinearLayout
        android:id="@+id/dialog_cert_info_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_section_panel"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/dialog_cert_info_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/hsp_accent_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialog_cert_info_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/hsp_text_muted"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Embedded into every patched APK for MITM proxy support."
            android:textColor="@color/hsp_text_faint"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- No-cert hint card -->
    <TextView
        android:id="@+id/dialog_cert_no_cert_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_section_panel"
        android:padding="12dp"
        android:text="Supports Reqable, Charles, mitmproxy and Burp Suite. Certificate is stored once and embedded in every patched APK automatically."
        android:textColor="@color/hsp_text_muted"
        android:textSize="12sp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#22FFFFFF" />

    <!-- ── Import / Replace action ── -->
    <LinearLayout
        android:id="@+id/dialog_cert_import"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_tools_option"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="82dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:id="@+id/dialog_cert_import_bar"
            android:layout_width="6dp"
            android:layout_height="42dp"
            android:background="@drawable/btn_primary_green" />

        <TextView
            android:id="@+id/dialog_cert_import_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="📥"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dialog_cert_import_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMPORT"
                android:textAllCaps="true"
                android:textColor="@color/hsp_accent_green"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialog_cert_import_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Import Certificate"
                android:textColor="@color/hsp_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialog_cert_import_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Select .crt / .pem / .cer / .der from storage"
                android:textColor="@color/hsp_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=">"
            android:textColor="@color/hsp_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialog_cert_import_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chip"
            android:paddingLeft="8dp"
            android:paddingTop="2dp"
            android:paddingRight="8dp"
            android:paddingBottom="2dp"
            android:text="ADD"
            android:textColor="@color/hsp_accent_green"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── Delete action (only shown when cert exists) ── -->
    <LinearLayout
        android:id="@+id/dialog_cert_delete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_tools_option"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="82dp"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone">

        <View
            android:layout_width="6dp"
            android:layout_height="42dp"
            android:background="@drawable/btn_danger" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="🗑"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DANGER"
                android:textAllCaps="true"
                android:textColor="@color/hsp_accent_red"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Remove Certificate"
                android:textColor="@color/hsp_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Permanently delete the stored CA certificate"
                android:textColor="@color/hsp_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=">"
            android:textColor="@color/hsp_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chip"
            android:paddingLeft="8dp"
            android:paddingTop="2dp"
            android:paddingRight="8dp"
            android:paddingBottom="2dp"
            android:text="DEL"
            android:textColor="@color/hsp_accent_red"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── Dismiss / Cancel row ── -->
    <LinearLayout
        android:id="@+id/dialog_cert_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_tools_option"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:layout_width="6dp"
            android:layout_height="28dp"
            android:background="@drawable/btn_surface" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/hsp_text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISMISS"
                android:textAllCaps="true"
                android:textColor="@color/hsp_text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Close"
                android:textColor="@color/hsp_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:text="MITM proxy certificate manager"
        android:textColor="@color/hsp_text_faint"
        android:textSize="11sp" />

</LinearLayout>
