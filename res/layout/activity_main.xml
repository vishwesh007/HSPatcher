<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_frame"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glass_root"
    android:clipChildren="false">

    <LinearLayout
        android:id="@+id/root_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/hsp_padding_screen"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/hsp_spacing_md"
            android:background="@drawable/bg_hero_panel"
            android:clipToPadding="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/hsp_spacing_lg">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_signal_badge"
                android:gravity="center"
                android:text="HP"
                android:textAllCaps="true"
                android:textColor="@color/hsp_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/hsp_spacing_md"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PATCH WORKSHOP"
                    android:textAllCaps="true"
                    android:textColor="@color/hsp_accent_teal"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.16" />

                <TextView
                    android:id="@+id/title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HSPatcher"
                    android:textSize="29sp"
                    android:textColor="@color/hsp_text"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitle_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stage, patch, sign, and reinstall with a calmer progress flow and clearer target context."
                    android:textColor="@color/hsp_text_muted"
                    android:textSize="13sp"
                    android:paddingTop="6dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/hsp_spacing_sm"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Persistent signing"
                        android:textSize="11sp"
                        android:textColor="@color/hsp_accent_green"
                        android:textStyle="bold"
                        android:paddingLeft="10dp"
                        android:paddingTop="4dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_chip" />

                    <TextView
                        android:id="@+id/version_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip"
                        android:paddingLeft="10dp"
                        android:paddingTop="4dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="4dp"
                        android:text=""
                        android:textColor="@color/hsp_text"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_tools"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="⚙"
                android:textColor="@color/hsp_text"
                android:textSize="20sp"
                android:background="@drawable/btn_surface"
                android:gravity="center"
                android:padding="0dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/apk_info_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/hsp_spacing_md"
            android:background="@drawable/bg_section_panel"
            android:orientation="vertical"
            android:padding="@dimen/hsp_spacing_lg"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE TARGET"
                android:textAllCaps="true"
                android:textColor="@color/hsp_accent_amber"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <TextView
                android:id="@+id/apk_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="19sp"
                android:textColor="@color/hsp_text"
                android:textStyle="bold"
                android:paddingTop="6dp" />

            <TextView
                android:id="@+id/apk_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/hsp_text_muted"
                android:paddingTop="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/hsp_spacing_lg"
            android:text="MISSION CONSOLE"
            android:textAllCaps="true"
            android:textColor="@color/hsp_accent_teal"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.16" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Normal-language status stays on top while the detailed log remains available below."
            android:textColor="@color/hsp_text_muted"
            android:textSize="12sp" />

        <ScrollView
            android:id="@+id/log_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="@dimen/hsp_spacing_sm"
            android:background="@drawable/bg_console_shell"
            android:padding="@dimen/hsp_spacing_lg"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls">

            <TextView
                android:id="@+id/log_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready. Select an APK to begin the next patch run."
                android:textSize="12sp"
                android:textColor="@color/hsp_text_mono"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp" />
        </ScrollView>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/hsp_spacing_md"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/hsp_accent_green"
            android:progressBackgroundTint="@color/hsp_glass_fill_strong"
            android:visibility="gone" />

        <TextView
            android:id="@+id/progress_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/hsp_accent_green"
            android:gravity="center"
            android:paddingTop="6dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/patch_game_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/hsp_spacing_md"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/hsp_spacing_md"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Patch Arcade"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/hsp_text" />

                <TextView
                    android:id="@+id/patch_game_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score 0  Streak 0"
                    android:textSize="12sp"
                    android:textColor="@color/hsp_accent_amber"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/patch_game_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="A lightweight micro-break while the patch pipeline completes its background stages."
                android:textSize="12sp"
                android:textColor="@color/hsp_text_faint" />

            <in.startv.hspatcher.PatchArcadeView
                android:id="@+id/patch_game_view"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/hsp_spacing_sm"
                android:background="@drawable/bg_log" />
        </LinearLayout>

        <!-- Phase 1: Initial — SELECT + EXTRACT -->
        <LinearLayout
            android:id="@+id/phase1_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/hsp_spacing_lg">

            <Button
                android:id="@+id/btn_select"
                android:layout_width="match_parent"
                android:layout_height="@dimen/hsp_btn_h_lg"
                android:text="🔧  SELECT APK"
                android:textColor="@color/hsp_text_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:stateListAnimator="@xml/press_scale"
                android:background="@drawable/btn_primary_green" />

            <Button
                android:id="@+id/btn_extract"
                android:layout_width="match_parent"
                android:layout_height="@dimen/hsp_btn_h_lg"
                android:text="📱  EXTRACT FROM INSTALLED APP"
                android:textColor="@color/hsp_text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:stateListAnimator="@xml/press_scale"
                android:background="@drawable/btn_primary_teal"
                android:layout_marginTop="@dimen/hsp_spacing_sm" />
        </LinearLayout>

        <!-- Phase 2: APK Selected — PATCH + CANCEL -->
        <LinearLayout
            android:id="@+id/phase2_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/hsp_spacing_lg"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_patch"
                android:layout_width="0dp"
                android:layout_height="@dimen/hsp_btn_h_lg"
                android:layout_weight="1"
                android:text="⚡ PATCH"
                android:textColor="@color/hsp_text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:stateListAnimator="@xml/press_scale"
                android:background="@drawable/btn_primary_purple"
                android:layout_marginEnd="@dimen/hsp_spacing_sm" />

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="@dimen/hsp_btn_h_lg"
                android:layout_weight="1"
                android:text="✕ CANCEL"
                android:textColor="@color/hsp_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:stateListAnimator="@xml/press_scale"
                android:background="@drawable/btn_cancel"
                android:layout_marginStart="@dimen/hsp_spacing_sm" />
        </LinearLayout>

        <!-- Phase 4: Patch Complete — INSTALL + UNINSTALL + MOD -->
        <LinearLayout
            android:id="@+id/phase4_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/hsp_spacing_lg"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_install"
                android:layout_width="match_parent"
                android:layout_height="@dimen/hsp_btn_h_lg"
                android:text="📲 INSTALL PATCHED APK"
                android:textColor="@color/hsp_text_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:stateListAnimator="@xml/press_scale"
                android:background="@drawable/btn_primary_amber" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/hsp_spacing_sm">

                <Button
                    android:id="@+id/btn_uninstall"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/hsp_btn_h_md"
                    android:layout_weight="1"
                    android:text="🗑 UNINSTALL"
                    android:textColor="@color/hsp_text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:stateListAnimator="@xml/press_scale"
                    android:background="@drawable/btn_danger"
                    android:layout_marginEnd="@dimen/hsp_spacing_sm" />

                <Button
                    android:id="@+id/btn_mod"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/hsp_btn_h_md"
                    android:layout_weight="1"
                    android:text="🔧 MOD ANOTHER"
                    android:textColor="@color/hsp_text_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:stateListAnimator="@xml/press_scale"
                    android:background="@drawable/btn_primary_green"
                    android:layout_marginStart="@dimen/hsp_spacing_sm" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Color fill overlay for button press effects -->
    <View
        android:id="@+id/color_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="2dp" />

    <!-- Particle container for explosion effect -->
    <FrameLayout
        android:id="@+id/particle_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:elevation="10dp" />

    <!-- FAB: CA Certificate -->
    <Button
        android:id="@+id/fab_cert"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/hsp_spacing_lg"
        android:layout_marginBottom="@dimen/hsp_spacing_lg"
        android:text="CA"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="0dp"
        android:background="@drawable/fab_cert"
        android:elevation="8dp"
        android:stateListAnimator="@xml/press_scale" />

</FrameLayout>
