<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_tools_shell"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:id="@+id/walkthrough_kicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="4dp"
        android:text="PATCH FLOW"
        android:textAllCaps="true"
        android:textColor="@color/hsp_accent_teal"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/walkthrough_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/hsp_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/walkthrough_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/hsp_text_muted"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/walkthrough_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_tools_option"
        android:gravity="center_vertical"
        android:minHeight="164dp"
        android:orientation="horizontal"
        android:padding="18dp">

        <TextView
            android:id="@+id/walkthrough_icon"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:textSize="25sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/walkthrough_step_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingLeft="8dp"
                android:paddingTop="3dp"
                android:paddingRight="8dp"
                android:paddingBottom="3dp"
                android:textColor="@color/hsp_accent_blue"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/walkthrough_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/hsp_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/walkthrough_step_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/hsp_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/walkthrough_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:id="@+id/walkthrough_dot_1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_chip" />

        <View
            android:id="@+id/walkthrough_dot_2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_chip" />

        <View
            android:id="@+id/walkthrough_dot_3"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_chip" />

        <View
            android:id="@+id/walkthrough_dot_4"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_chip" />

        <View
            android:id="@+id/walkthrough_dot_5"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_chip" />
    </LinearLayout>

    <TextView
        android:id="@+id/walkthrough_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="You can reopen this guide from the tools button any time."
        android:textColor="@color/hsp_text_faint"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/walkthrough_skip"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/btn_surface"
            android:text="Skip"
            android:textAllCaps="false"
            android:textColor="@color/hsp_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/walkthrough_next"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/btn_primary_green"
            android:text="Next"
            android:textAllCaps="false"
            android:textColor="@color/hsp_text_dark"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>