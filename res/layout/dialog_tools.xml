<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog_tools_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TOOLS"
        android:textAllCaps="true"
        android:textColor="@color/hsp_accent_teal"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Choose a utility"
        android:textColor="@color/hsp_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Signing and database inspection in one place"
        android:textColor="@color/hsp_text_muted"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/dialog_tools_signer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_tools_option"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="86dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:layout_width="6dp"
            android:layout_height="42dp"
            android:background="@drawable/btn_primary_signer" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APK SIGNER"
                android:textAllCaps="true"
                android:textColor="@color/hsp_accent_blue"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Sign patched APKs"
                android:textColor="@color/hsp_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Re-sign packages quickly with the built-in signer"
                android:textColor="@color/hsp_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=">"
            android:textColor="@color/hsp_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/dialog_tools_db"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_tools_option"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="86dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:layout_width="6dp"
            android:layout_height="42dp"
            android:background="@drawable/btn_tool_dbeditor" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATABASE"
                android:textAllCaps="true"
                android:textColor="@color/hsp_accent_green"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="DB Editor"
                android:textColor="@color/hsp_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Browse tables, inspect rows, and edit SQLite files"
                android:textColor="@color/hsp_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=">"
            android:textColor="@color/hsp_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
