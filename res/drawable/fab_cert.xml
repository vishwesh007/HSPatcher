<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/hsp_ripple">
    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="#FF4A342C"
                        android:endColor="#FF2F211C" />
                    <stroke android:width="1dp" android:color="@color/hsp_glass_stroke" />
                </shape>
            </item>
            <item android:insetLeft="4dp" android:insetTop="4dp" android:insetRight="4dp" android:insetBottom="4dp">
                <shape android:shape="oval">
                    <solid android:color="#22FFFFFF" />
                    <stroke android:width="1dp" android:color="#33FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
