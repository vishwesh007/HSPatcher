<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#33151A21" />
            <corners android:radius="@dimen/hsp_radius_md" />
            <stroke android:width="1dp" android:color="#22303640" />
        </shape>
    </item>

    <item>
        <ripple android:color="@color/hsp_ripple">
            <item>
                <shape>
                    <solid android:color="@color/hsp_surface" />
                    <corners android:radius="@dimen/hsp_radius_md" />
                    <stroke android:width="1dp" android:color="@color/hsp_border" />
                </shape>
            </item>
        </ripple>
    </item>
</selector>
