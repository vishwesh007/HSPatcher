<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="0"
                android:startColor="#243CDACD"
                android:endColor="#1837B6FF" />
            <corners android:radius="999dp" />
            <stroke android:width="1dp" android:color="#4B9FE9FF" />
        </shape>
    </item>
    <item android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
        <shape>
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#2CF4FDFF"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>