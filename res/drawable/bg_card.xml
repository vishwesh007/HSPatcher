<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <solid android:color="@color/hsp_glass_fill_strong" />
            <corners android:radius="@dimen/hsp_radius_lg" />
            <stroke android:width="1dp" android:color="@color/hsp_glass_stroke" />
        </shape>
    </item>

    <!-- Inner highlight -->
    <item>
        <inset android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
            <shape>
                <corners android:radius="@dimen/hsp_radius_lg" />
                <gradient
                    android:angle="270"
                    android:startColor="@color/hsp_glass_highlight"
                    android:endColor="#00FFFFFF" />
            </shape>
        </inset>
    </item>

</layer-list>
