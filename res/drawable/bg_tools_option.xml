<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/hsp_ripple">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/hsp_glass_fill"
                android:startColor="@color/hsp_glass_fill_strong" />
            <stroke
                android:width="1dp"
                android:color="@color/hsp_glass_stroke" />
            <corners android:radius="18dp" />
            <padding
                android:bottom="2dp"
                android:left="2dp"
                android:right="2dp"
                android:top="2dp" />
        </shape>
    </item>
</ripple>
