<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/hsp_ripple">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#28163340"
                android:endColor="#2028A7CA" />
            <stroke
                android:width="1dp"
                android:color="#429AEAFF" />
            <corners android:radius="20dp" />
            <padding
                android:bottom="2dp"
                android:left="2dp"
                android:right="2dp"
                android:top="2dp" />
        </shape>
    </item>
</ripple>
