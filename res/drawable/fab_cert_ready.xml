<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/hsp_ripple">
    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="#FF163428"
                        android:endColor="#FF0F261D" />
                    <stroke android:width="1dp" android:color="#5532D583" />
                </shape>
            </item>
            <item android:insetLeft="4dp" android:insetTop="4dp" android:insetRight="4dp" android:insetBottom="4dp">
                <shape android:shape="oval">
                    <solid android:color="#2200E676" />
                    <stroke android:width="1dp" android:color="#4000E676" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
