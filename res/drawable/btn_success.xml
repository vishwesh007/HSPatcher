<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#332E7D32" />
            <corners android:radius="@dimen/hsp_radius_md" />
        </shape>
    </item>

    <item>
        <ripple android:color="@color/hsp_ripple">
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/hsp_legacy_success" />
                    <corners android:radius="@dimen/hsp_radius_md" />
                </shape>
            </item>
        </ripple>
    </item>
</selector>
