<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base dark gradient -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="@color/hsp_bg"
                android:centerColor="@color/hsp_surface_alt"
                android:endColor="@color/hsp_surface" />
        </shape>
    </item>

    <!-- Subtle top-left highlight for "glass" depth -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="560dp"
                android:centerX="0.15"
                android:centerY="0.10"
                android:startColor="#14FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>

</layer-list>
