<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#FF12202A"
                android:endColor="#FF09131A" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#4C95E8FF" />
        </shape>
    </item>
    <item android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
        <shape>
            <corners android:radius="23dp" />
            <gradient
                android:angle="270"
                android:startColor="#28F4FDFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
