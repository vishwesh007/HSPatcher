<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#CC061017"
                android:endColor="#D40A151D" />
            <corners android:radius="@dimen/hsp_radius_md" />
            <stroke android:width="1dp" android:color="#3C63D5F0" />
        </shape>
    </item>

    <item>
        <inset android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
            <shape>
                <corners android:radius="@dimen/hsp_radius_md" />
                <gradient
                    android:angle="270"
                    android:startColor="#1AF4FDFF"
                    android:endColor="#00FFFFFF" />
            </shape>
        </inset>
    </item>

</layer-list>
